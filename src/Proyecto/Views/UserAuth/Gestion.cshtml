@using Proyecto.Models.Domain
@model IEnumerable<ApplicationUser>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestión de Usuarios";
}

<main class="flex-1 overflow-y-auto p-6">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Gestión de Usuarios</h1>
            <p class="text-sm text-slate-500 mt-1">Administración de accesos y roles del sistema FoodRoute</p>
        </div>
        
        <a href="/UserAuth/Registro" class="inline-flex items-center gap-2 bg-brand hover:bg-emerald-700 text-white px-4 py-2.5 rounded-lg font-medium transition-colors shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nuevo Empleado
        </a>
    </div>

    @if (TempData["Msg"] != null)
    {
        <div class="mb-6 p-4 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            @TempData["Msg"]
        </div>
    }

    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h2 class="text-base font-semibold text-slate-800">Usuarios Registrados</h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50/80">
                        <th class="px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Nombre Completo</th>
                        <th class="px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Usuario</th>
                        <th class="px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Email</th>
                        <th class="px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Acciones de Rol</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                @(string.IsNullOrEmpty(user.Nombre_completo) ? "Sin nombre" : user.Nombre_completo)
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500">@user.UserName</td>
                            <td class="px-6 py-4 text-sm text-gray-500">@user.Email</td>
                            <td class="px-6 py-4 text-right">
                                <form asp-controller="UserAuth" asp-action="UpdateRole" method="post" class="inline-flex items-center gap-2">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    
                                    <select name="newRole" class="text-sm border-gray-300 rounded-lg py-1.5 pl-3 pr-8 focus:ring-brand focus:border-brand text-slate-700 bg-slate-50">
                                        <option value="">Seleccionar rol...</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Vendedor">Vendedor</option>
                                        <option value="Usuario">Usuario (Operario)</option>
                                    </select>
                                    
                                    <button type="submit" class="bg-brand text-white text-sm font-medium px-4 py-1.5 rounded-lg hover:bg-emerald-700 transition-colors">
                                        Asignar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <div class="px-6 py-3.5 border-t border-slate-100">
            <p class="text-xs text-slate-500">Mostrando @Model.Count() usuarios en el sistema</p>
        </div>
    </div>

    <a href="/UserAuth/Gestion" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    Gestión de Usuarios
</a>


</main>