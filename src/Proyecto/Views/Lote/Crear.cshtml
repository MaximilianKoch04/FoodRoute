@model Proyecto.Models.Domain.Lote
@{
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto p-8 bg-white shadow-lg rounded-xl border border-slate-200 mt-10">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-2xl font-bold text-slate-800">Ingreso de Nuevo Lote</h2>
            <p class="text-sm text-slate-500 mt-1">Registrar mercadería del proveedor</p>
        </div>
        <a href="/Producto" class="text-sm text-slate-500 hover:text-slate-800 transition-colors">Volver al catálogo</a>
    </div>

    <form asp-controller="Lote" asp-action="Crear" method="post">
        <div class="space-y-5">
            
            <div>
                <label asp-for="IdProducto" class="block text-sm font-medium text-slate-700 mb-1">Producto que ingresa</label>
                <select asp-for="IdProducto" asp-items="@(ViewBag.Productos as SelectList)" class="block w-full border border-slate-300 rounded-lg shadow-sm p-2.5 focus:ring-emerald-500 focus:border-emerald-500 bg-white">
    <option value="">-- Seleccione un producto --</option>
</select>
            </div>

            <div>
                <label asp-for="CodigoLote" class="block text-sm font-medium text-slate-700 mb-1">Código de Lote / N° Remito</label>
                <input asp-for="CodigoLote" class="block w-full border border-slate-300 rounded-lg shadow-sm p-2.5 focus:ring-emerald-500 focus:border-emerald-500" placeholder="Ej: REM-1024" />
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="StockActualLote" class="block text-sm font-medium text-slate-700 mb-1">Cantidad (Kg)</label>
                    <input asp-for="StockActualLote" type="number" step="0.01" class="block w-full border border-slate-300 rounded-lg shadow-sm p-2.5 focus:ring-emerald-500 focus:border-emerald-500" placeholder="Ej: 50" />
                </div>

                <div>
                    <label asp-for="FechaVencimiento" class="block text-sm font-medium text-slate-700 mb-1">Fecha de Vencimiento</label>
                    <input asp-for="FechaVencimiento" type="date" class="block w-full border border-slate-300 rounded-lg shadow-sm p-2.5 focus:ring-emerald-500 focus:border-emerald-500" />
                </div>
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full bg-emerald-600 text-white py-2.5 px-4 rounded-lg hover:bg-emerald-700 transition-colors font-semibold shadow-sm flex justify-center items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Confirmar Ingreso a Depósito
                </button>
            </div>
        </div>
    </form>
</div>