@model Proyecto.Models.Domain.Producto
@{
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto p-8 bg-white shadow-lg rounded-lg mt-10">
    <h2 class="text-2xl font-bold mb-6 text-gray-800">Registrar Nuevo Producto</h2>

    <form asp-action="Crear" method="post">
        <div class="space-y-4">
            <div>
                <label asp-for="Nombre" class="block text-sm font-medium text-gray-700">Nombre del Producto</label>
                <input asp-for="Nombre" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-emerald-500 focus:border-emerald-500" placeholder="Ej: Cebolla Morada" />
            </div>

            <div>
                <label asp-for="PrecioBase" class="block text-sm font-medium text-gray-700">Precio Base</label>
                <input asp-for="PrecioBase" type="number" step="0.01" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-emerald-500 focus:border-emerald-500" />
            </div>

            <div class="flex items-center mt-4">
                <input asp-for="RequiereFrio" type="checkbox" class="h-4 w-4 text-emerald-600 border-gray-300 rounded focus:ring-emerald-500" />
                <label asp-for="RequiereFrio" class="ml-2 block text-sm text-gray-900">¿Requiere refrigeración continua?</label>
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full bg-emerald-600 text-white py-2 px-4 rounded-md hover:bg-emerald-700 transition font-bold shadow-md">
                    Guardar Producto en Base de Datos
                </button>
            </div>
        </div>
    </form>
</div>