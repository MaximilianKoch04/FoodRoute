@model IEnumerable<Proyecto.Models.Domain.Producto>
@{
    Layout = "_Layout";
}

<main class="flex-1 overflow-y-auto p-6">
    @if (TempData["Error"] != null)
    {   
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r shadow-sm">
        <div class="flex items-center">
            <svg class="h-5 w-5 text-red-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.78 7.5a.75.75 0 011.44 0v4.5a.75.75 0 01-1.44 0v-4.5zM10 15a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
            </svg>
            <p class="text-sm text-red-700 font-medium">@TempData["Error"]</p>
        </div>
    </div>
    }
    <div class="mb-6 flex justify-between items-center">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Catálogo de Productos</h1>
            <p class="text-sm text-slate-500 mt-1">Gestión maestra de artículos y sus propiedades</p>
        </div>
        
        <a href="/Producto/Crear" class="inline-flex items-center gap-2 px-4 py-2 bg-brand hover:bg-emerald-600 text-white text-sm font-medium rounded-lg shadow-sm transition-colors" style="background-color: #10b981;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nuevo Producto
        </a>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <table class="w-full">
            <thead>
                <th>Acciones</th>
                <tr class="bg-slate-50/80 border-b border-slate-200">
                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-4">Nombre</th>
                    <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-4">Precio Base</th>
                    <th class="text-center text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-4">¿Requiere Frío?</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
    @foreach (var item in Model)
    {
        <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4 text-sm font-medium text-slate-800">@item.Nombre</td>
            <td class="px-6 py-4 text-sm text-slate-600">$ @item.PrecioBase</td>
            <td class="px-6 py-4 text-sm text-center">
                @(item.RequiereFrio ? "SÍ" : "NO")
            </td>
            
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex justify-end gap-2">
                    <a href="/Lote/Crear?productoId=@item.IdProducto" class="text-emerald-600 hover:text-emerald-900 bg-emerald-50 px-2 py-1 rounded">
    + Stock
</a>
                    <a href="/Producto/Editar/@item.IdProducto" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 px-2 py-1 rounded">
                        Editar
                    </a>
                    <form action="/Producto/Eliminar/@item.IdProducto " method="post" onsubmit="return confirm('¿Seguro que querés eliminarlo?');" class="inline">
                        <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 px-2 py-1 rounded">
                            Eliminar
                        </button>
                    </form>
                </div>
            </td>
        </tr>
    }
</tbody>
        </table>
    </div>
</main>