@model Proyecto.Models.Domain.Producto
@{
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto p-8 bg-white shadow-lg rounded-xl border border-slate-200 mt-10">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-800">Editar Producto</h2>
        <a href="/Producto" class="text-sm text-slate-500 hover:text-slate-800 transition-colors">Volver al catálogo</a>
    </div>

    <form asp-controller="Producto" asp-action="Editar" method="post">
        
        <input type="hidden" asp-for="IdProducto" />

        <div class="space-y-5">
            <div>
                <label asp-for="Nombre" class="block text-sm font-medium text-slate-700 mb-1">Nombre del Producto</label>
                <input asp-for="Nombre" class="block w-full border border-slate-300 rounded-lg shadow-sm p-2.5 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" />
            </div>

            <div>
                <label asp-for="PrecioBase" class="block text-sm font-medium text-slate-700 mb-1">Precio Base ($)</label>
                <input asp-for="PrecioBase" type="number" step="0.01" class="block w-full border border-slate-300 rounded-lg shadow-sm p-2.5 focus:ring-indigo-500 focus:border-indigo-500 transition-colors" />
            </div>

            <div class="flex items-center p-4 bg-slate-50 rounded-lg border border-slate-200 mt-2">
                <input asp-for="RequiereFrio" type="checkbox" class="h-5 w-5 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" />
                <div class="ml-3">
                    <label asp-for="RequiereFrio" class="block text-sm font-medium text-slate-900">Requiere refrigeración continua</label>
                    <p class="text-xs text-slate-500">Marcar solo si debe ir en la cámara de frío.</p>
                </div>
            </div>

            <div class="pt-6">
                <button type="submit" class="w-full bg-indigo-600 text-white py-2.5 px-4 rounded-lg hover:bg-indigo-700 transition-colors font-semibold shadow-sm">
                    Guardar Cambios
                </button>
            </div>
        </div>
    </form>
</div>