<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - FoodRoute</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sidebar: '#14532D',
            'sidebar-hover': '#166534',
            'sidebar-active': '#15803D',
            brand: '#16A34A',
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
        },
      },
    };
  </script>
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
  </style>
</head>
<body class="bg-slate-50 h-screen flex overflow-hidden">

  <aside class="w-64 bg-sidebar flex flex-col shrink-0 h-screen">
    <div class="px-6 py-6 flex items-center gap-3">
      <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l4-2 4 2zM13 6h5l3 4v6a1 1 0 01-1 1h-1M6 19a2 2 0 104 0M14 19a2 2 0 104 0" />
        </svg>
      </div>
      <span class="text-white font-bold text-lg tracking-tight">FoodRoute</span>
    </div>

    <nav class="flex-1 px-3 py-4 flex flex-col gap-1">
      <a href="/Home" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white hover:bg-sidebar-hover text-sm font-medium transition-colors">Inicio</a>
      <a href="/Producto" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">Catálogo</a>
    </a>
    <a href="/Proveedor/Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
    </svg>
    Proveedores
</a>
<a href="/Cliente/Index" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
    Clientes
</a>
    
    @if (User.IsInRole("Admin"))
    {
        <div class="mx-2 my-2 border-t border-white/10"></div>
        <p class="px-3 text-[10px] font-bold text-white/40 uppercase tracking-widest mb-1">Administración</p>
        
        <a href="/UserAuth/Gestion" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white bg-sidebar-active shadow-sm text-sm font-medium transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            Gestión de Usuarios
        </a>
    }
    </nav>
  </aside>

  <div class="flex-1 flex flex-col h-screen overflow-hidden">

    <header class="bg-white border-b border-slate-200 px-6 py-3 flex items-center justify-between shrink-0">
      <div class="relative w-full max-w-md">
        <input type="text" placeholder="Buscar..." class="w-full pl-10 pr-4 py-2 text-sm bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand/30 transition-all" />
      </div>

      <div class="flex items-center gap-4">
        <button class="p-2 rounded-lg hover:bg-slate-100 transition-colors">Notificaciones</button>
        <div class="w-px h-8 bg-slate-200"></div>

        <div class="flex items-center gap-3">
            <div class="text-right hidden sm:block">
                <p class="text-sm font-bold text-slate-800">@User?.Identity?.Name</p>
                <p class="text-[10px] text-emerald-600 font-bold uppercase tracking-wider">Administrador</p>
            </div>
            
            <div class="h-9 w-9 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-700 font-bold border border-emerald-200">
                @User?.Identity?.Name?.Substring(0, 1).ToUpper()
            </div>

            <form asp-controller="UserAuth" asp-action="Logout" method="post" class="ml-2">
                <button type="submit" class="p-2 text-slate-400 hover:text-red-600 transition-colors" title="Cerrar Sesión">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                </button>
            </form>
        </div>
      </div>
    </header>

    <main class="flex-1 overflow-y-auto bg-slate-50">
      @RenderBody()
    </main>

  </div>

  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>