<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - FoodRoute</title>
  
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            sidebar: '#14532D',
            'sidebar-hover': '#166534',
            'sidebar-active': '#15803D',
            brand: '#16A34A',
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'sans-serif'],
          },
        },
      },
    };
  </script>
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
  </style>
</head>
<body class="bg-slate-50 h-screen flex overflow-hidden">

  <aside class="w-64 bg-sidebar flex flex-col shrink-0 h-screen">
    <div class="px-6 py-6 flex items-center gap-3">
      <div class="w-9 h-9 bg-brand rounded-lg flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l4-2 4 2zM13 6h5l3 4v6a1 1 0 01-1 1h-1M6 19a2 2 0 104 0M14 19a2 2 0 104 0" />
        </svg>
      </div>
      <span class="text-white font-bold text-lg tracking-tight">FoodRoute</span>
    </div>

    <div class="mx-4 border-t border-white/10"></div>

    <nav class="flex-1 px-3 py-4 flex flex-col gap-1">
      <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-sidebar-active text-white text-sm font-medium transition-colors">
        Inicio
      </a>
      <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">
        Ingreso de Remitos
      </a>
      <a href="/Producto" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">
        Catálogo
      </a>
      <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-white/70 hover:bg-sidebar-hover hover:text-white text-sm font-medium transition-colors">
        Bajas y Mermas
      </a>
    </nav>

    <div class="px-4 py-4 border-t border-white/10">
      <div class="flex items-center gap-3 px-2">
        <div class="w-8 h-8 bg-brand/30 rounded-full flex items-center justify-center">
          <span class="text-white text-xs font-semibold">N1</span>
        </div>
        <div>
          <p class="text-white text-xs font-medium">Nave 1</p>
          <p class="text-white/50 text-xs">Zona Fría</p>
        </div>
      </div>
    </div>
  </aside>

  <div class="flex-1 flex flex-col h-screen overflow-hidden">

    <header class="bg-white border-b border-slate-200 px-6 py-3.5 flex items-center justify-between shrink-0">
      <div class="relative w-full max-w-md">
        <input type="text" placeholder="Buscar producto, lote o remito..." class="w-full pl-10 pr-4 py-2 text-sm bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand placeholder-slate-400 transition-all" />
      </div>

      <div class="flex items-center gap-4 ml-6 shrink-0">
        <button class="relative p-2 rounded-lg hover:bg-slate-100 transition-colors">Notificaciones <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span></button>
        <div class="w-px h-8 bg-slate-200"></div>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-brand rounded-full flex items-center justify-center">
            <span class="text-white text-sm font-semibold">JR</span>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-800 leading-tight">Juan Rodríguez</p>
            <p class="text-xs text-slate-500">Encargado de Nave 1</p>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1 overflow-y-auto p-6">
      @RenderBody()
    </main>

  </div>

  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>