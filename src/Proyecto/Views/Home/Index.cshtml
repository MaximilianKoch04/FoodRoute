@using Proyecto.Models.Emuns;
@model IEnumerable<Proyecto.Models.Domain.Lote>

@{
    Layout = "_Layout";
}

<main class="flex-1 overflow-y-auto p-6">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Panel de Control de Inventario (FEFO)</h1>
        <p class="text-sm text-slate-500 mt-1">Gestión de stock con criterio First Expired, First Out</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">

        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Stock Físico Total</p>
            <p class="text-3xl font-bold text-slate-800 mt-2">@ViewBag.StockTotal.ToString("N0")</p>
            <p class="text-sm text-slate-500 mt-1">kilogramos en nave</p>
        </div>

        <div class="bg-white rounded-xl border border-red-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Lotes Próximos a Vencer</p>
            <p class="text-3xl font-bold text-red-600 mt-2">@ViewBag.ProximosAVencer</p>
            <p class="text-sm text-red-500 mt-1 font-medium">Requieren atención urgente</p>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Remitos de Hoy</p>
            <p class="text-3xl font-bold text-slate-800 mt-2">4</p>
            <p class="text-sm text-slate-500 mt-1">remitos procesados</p>
        </div>

    </div> <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
            <h2 class="text-base font-semibold text-slate-800">Últimos Lotes Ingresados</h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50/80">
                        <th class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-3">ID Lote</th>
                        <th class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-3">Producto</th>
                        <th class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-3">Fecha de Vencimiento</th>
                        <th class="text-right text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-3">Cantidad (Kg)</th>
                        <th class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-6 py-3">Estado</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var lote in Model)
                    {
                        string colorFondo = "";
                        string colorTexto = "";
                        string textoEstado = "";

                        if (lote.Estado == EstadoLote.Disponible)
                        {
                            colorFondo = "bg-green-100";
                            colorTexto = "text-green-800";
                            textoEstado = "Vigente";
                        }
                        else if (lote.Estado == EstadoLote.ProximoAVencer)
                        {
                            colorFondo = "bg-yellow-100";
                            colorTexto = "text-yellow-800";
                            textoEstado = "Por Vencer";
                        }
                        else if (lote.Estado == EstadoLote.Vencido)
                        {
                            colorFondo = "bg-red-100";
                            colorTexto = "text-red-800";
                            textoEstado = "Vencido";
                        }

                        <tr>
                            <td class="px-6 py-4 text-sm font-medium text-gray-900">@lote.CodigoLote</td>
                            <td class="px-6 py-4 text-sm text-gray-500">@lote.Producto.Nombre</td>
                            <td class="px-6 py-4 text-sm text-gray-500">@lote.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                            <td class="px-6 py-4 text-sm text-gray-500 text-right">@lote.StockActualLote kg</td>
                            <td class="px-6 py-4">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full @colorFondo @colorTexto">
                                    @textoEstado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-6 py-3.5 border-t border-slate-100">
            <p class="text-xs text-slate-500">Mostrando @Model.Count() lotes activos</p>
        </div>
    </div>
</main>